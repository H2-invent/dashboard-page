{% extends 'base.html.twig' %}

{% block title %}Willkommen | Landingpage{% endblock %}

{% block body %}
    <main class="relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 -z-10 h-[34rem] bg-gradient-to-br from-cyan-100 via-white to-violet-100 blur-3xl"></div>
        <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6 py-10 lg:px-8">
            <header class="mb-12 flex flex-col gap-6 rounded-[2rem] border border-white/70 bg-white/80 p-8 shadow-soft backdrop-blur xl:flex-row xl:items-center xl:justify-between">
                <div class="max-w-2xl space-y-4">
                    <span class="inline-flex items-center rounded-full bg-cyan-100 px-3 py-1 text-sm font-medium text-cyan-800">
                        {{ header.badge }}
                    </span>
                    <div class="space-y-3">
                        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-700">
                            {{ personalGreeting }}
                        </p>
                        <h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
                            {{ header.title }}
                        </h1>
                        <p class="text-lg leading-8 text-slate-600">
                            {{ header.description }}
                        </p>
                    </div>
                </div>
                <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 text-sm text-slate-600 shadow-sm">
                    <p class="font-medium text-slate-900">Angemeldet als</p>
                    <p class="mt-2 text-base font-semibold text-slate-950">{{ user.displayName ?? user.userIdentifier }}</p>
                    <p class="mt-1">{{ user.email ?? 'Kein Profilattribut vorhanden' }}</p>
                    <a
                        class="mt-4 inline-flex items-center rounded-full border border-slate-200 px-4 py-2 font-medium text-slate-700 transition hover:border-slate-300 hover:bg-white"
                        href="{{ path('app_logout') }}"
                    >
                        Logout
                    </a>
                </div>
            </header>

            <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                {% for link in links %}
                    <a
                        href="{{ link.url }}"
                        target="_blank"
                        rel="noreferrer noopener"
                        class="group relative overflow-hidden rounded-[2rem] border border-white/70 bg-white p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:shadow-2xl"
                    >
                        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r {{ link.color }}"></div>
                        <div class="flex h-full flex-col justify-between gap-10">
                            <div class="space-y-4">
                                <div class="inline-flex h-14 w-14 items-center justify-center overflow-hidden rounded-2xl bg-slate-100 p-2 ring-1 ring-slate-200 transition group-hover:bg-white">
                                    {% if link.image is defined and link.image %}
                                        <img
                                            src="{{ link.image }}"
                                            alt="{{ link.text }} Logo"
                                            class="h-full w-full rounded-xl object-contain"
                                            loading="lazy"
                                        >
                                    {% elseif link.icon is defined and link.icon %}
                                        {{ app_icon(link.icon)|raw }}
                                    {% endif %}
                                </div>
                                <div class="space-y-2">
                                    <h2 class="text-xl font-semibold text-slate-950">{{ link.text }}</h2>
                                    <p class="text-sm leading-6 text-slate-500">
                                        {{ link.url }}
                                    </p>
                                </div>
                            </div>
                            <div class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700 transition group-hover:text-slate-950">
                                Link öffnen
                                <span aria-hidden="true">→</span>
                            </div>
                        </div>
                    </a>
                {% else %}
                    <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white/70 p-8 text-slate-600 shadow-sm md:col-span-2 xl:col-span-3">
                        Keine Links konfiguriert. Ergänze Einträge in <code>config/packages/app_links.yaml</code>.
                    </div>
                {% endfor %}
            </section>
        </div>
    </main>
{% endblock %}
